<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Emu86</RootNamespace>
    <AssemblyName>Emu86</AssemblyName>
  </PropertyGroup>

  <!--
    BIOS イメージを同梱する場合は bios.bin をプロジェクト直下に置けば自動で埋め込まれ、
    EmuEnvironment が起動時に 1MB メモリ空間の末尾へ配置する。
  -->
  <ItemGroup>
    <EmbeddedResource Include="bios.bin" Condition="Exists('bios.bin')" />
  </ItemGroup>

</Project>
